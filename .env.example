# ──────────────────────────────────────────────────────────────────────────
# TruthBounty Agora — agent env. Copy values into .env.local.
# Addresses come from: Circle CCTP contracts page + Azuro gem.azuro.org (Amoy).
# ──────────────────────────────────────────────────────────────────────────

# Agent brain
ANTHROPIC_API_KEY=
AGENT_MODEL=claude-opus-4-7

# The agent's signer — controls the USDC book on Arc. Testnet key only.
AGENT_PRIVATE_KEY=0x...

# App base url (so server routes can fetch sibling /api routes)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# TruthBounty deployed API — the live source of reputation + market signal.
# The agent reads /api/unified-leaderboard and /api/{azuro,overtime,polymarket} here.
TRUTHBOUNTY_API_URL=https://truthbounty.xyz

# ── Circle CCTP V2 ──────────────────────────────────────────────────────────
# Iris attestation service (sandbox = testnet)
CCTP_IRIS_URL=https://iris-api-sandbox.circle.com

# Arc testnet — CONFIRMED from docs.arc.network. Public RPC, no token needed.
# Fund the agent wallet with USDC at https://faucet.circle.com (select Arc).
ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_CCTP_DOMAIN=26
ARC_USDC=0x3600000000000000000000000000000000000000
ARC_TOKEN_MESSENGER=0x8FE6B999Dc680CcFDD5Bf7EB0974218be2542DAA
ARC_MESSAGE_TRANSMITTER=0xE737e5cEBEEBa77EFE34D4aa090756590b1CE275
# Circle Gateway (on-chain) on Arc — real contracts, not an opaque API
ARC_GATEWAY_WALLET=0x0077777d7EBA4688BDeF3E311b846F25870A19B9
ARC_GATEWAY_MINTER=0x0022222ABE238Cc2C7Bb1f21003F0a260052475B
# CycleRegistry: our deployed contract that attests each decision cycle on Arc
ARC_CYCLE_REGISTRY=0x68C36965fEA665fB53Fb0590aCcD4E99B64c49FB

# Polygon Amoy (domain 7) — Azuro + Polymarket execution chain
POLYGON_AMOY_RPC_URL=
POLYGON_AMOY_USDC=0x41E94Eb019C0762f9Bfcf9Fb1E58725BfB0e7582
POLYGON_AMOY_TOKEN_MESSENGER=0x8FE6B999Dc680CcFDD5Bf7EB0974218be2542DAA
POLYGON_AMOY_MESSAGE_TRANSMITTER=0xE737e5cEBEEBa77EFE34D4aa090756590b1CE275

# Base Sepolia (domain 6) — Overtime execution chain (gated stretch)
BASE_SEPOLIA_RPC_URL=
BASE_SEPOLIA_USDC=0x036CbD53842c5426634e7929541eC2318f3dCF7e
BASE_SEPOLIA_TOKEN_MESSENGER=0x8FE6B999Dc680CcFDD5Bf7EB0974218be2542DAA
BASE_SEPOLIA_MESSAGE_TRANSMITTER=0xE737e5cEBEEBa77EFE34D4aa090756590b1CE275

# ── Azuro V3 (Polygon Amoy, v3.0.13) ────────────────────────────────────────
# NOTE: V3 has NO ProxyFront. Bets go via Relayer.betFor(OrderData[]) and need a
# bettorSignature + an oracleSignature from Azuro's Live Betting API. The agent
# signs the bettor side; the API supplies odds + the oracle co-signature.
AZURO_LP=0x0a75395Ff15d9557424b632cEBCac448D66F9779
AZURO_VAULT=0x1Ed6CEEDf7033461a189FD7c3381C34846D7b25a
AZURO_CLIENT_CORE=0xCD0Db5ef28C3Bd3a69283372dE923Eb4DA0585F6
AZURO_AZUROBET=0x4B75c071dFA5d537979E8b0615Bb97B6337dbFef
AZURO_RELAYER=0x48c9bE88706F22838070eE7C4bC74Ad7A8eeF114
AZURO_BET_TOKEN=0xCf1b86ceD971b88C042C64A9c099377e2738073C
AZURO_LIVE_API_URL=

# ── Circle Gateway / Paymaster (Arc) ────────────────────────────────────────
# Gateway powers the agent wallet + USDC nanopayments; Paymaster pays gas in USDC.
GATEWAY_API_URL=
GATEWAY_API_KEY=
ARC_PAYMASTER=

# x402 nanopayments: the agent signs EIP-3009 transferWithAuthorization over Arc
# USDC. Name/version are the USDC EIP-712 domain fields; payee is who it pays for
# intelligence (TruthBounty). Defaults make a keyless decision run still work.
ARC_CHAIN_ID=5042002
ARC_USDC_NAME=USDC
ARC_USDC_VERSION=2
INTELLIGENCE_PAYEE=
